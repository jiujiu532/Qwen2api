# ============================================================
# Qwen2api Configuration
# Copy to .env and modify as needed
# ============================================================

# --- Core ---
ADMIN_KEY=123456
PORT=7860
ENGINE_MODE=httpx
DEFAULT_STREAM=true

# --- Account Pool ---
MAX_INFLIGHT=1
ACCOUNT_MIN_INTERVAL_MS=300
REQUEST_JITTER_MIN_MS=30
REQUEST_JITTER_MAX_MS=100
MAX_RETRIES=3

# --- Auto Registration ---
AUTO_REPLENISH=false
REPLENISH_TARGET=30
REPLENISH_CONCURRENCY=3
REPLENISH_PROVIDER=

# --- Mail Channels ---
MOEMAIL_DOMAIN=
MOEMAIL_KEY=
TEMPMAIL_DOMAIN=
TEMPMAIL_KEY=
SMARTMAIL_KEY=
VIPMAIL_KEY=

# --- Proxy ---
PROXY_ENABLED=false
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# --- Image ---
IMAGE_FORMAT=local_md
IMAGE_CACHE_MAX_MB=100

# --- WebUI ---
WEBUI_ENABLED=true
WEBUI_KEY=

# --- Timeouts (seconds) ---
TIMEOUT_CHAT=60
TIMEOUT_IMAGE=60
TIMEOUT_STREAM_IDLE=60
TIMEOUT_REGISTER=60

# --- Streaming ---
STREAM_KEEPALIVE_INTERVAL=5
STREAM_MAX_CHUNK_SIZE=4
STREAM_CHUNK_DELAY_MS=30

# --- Advanced ---
NATIVE_TOOL_PASSTHROUGH=true
BROWSER_POOL_SIZE=2
RATE_LIMIT_BASE_COOLDOWN=600
RATE_LIMIT_MAX_COOLDOWN=3600

# --- Data Paths (Docker) ---
ACCOUNTS_FILE=/workspace/data/accounts.json
USERS_FILE=/workspace/data/users.json
CAPTURES_FILE=/workspace/data/captures.json
CONFIG_FILE=/workspace/data/config.json

# --- App URL (for image proxy, leave empty for auto-detect) ---
APP_URL=
